{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pagemaker365.com/schemas/onboarding-status.schema.json",
  "title": "PageMaker365 Onboarding Status Response",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "sessionId",
    "status",
    "correlationId",
    "packageReadiness"
  ],
  "properties": {
    "contractVersion": {
      "type": "string"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "customerName": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "portalRecordUrl": {
      "type": "string"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "lastSyncAt": {
      "type": "string",
      "format": "date-time"
    },
    "missingFields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fieldKey",
          "label"
        ],
        "properties": {
          "fieldKey": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "source": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "packageReadiness": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "packageVersion": {
          "type": "string"
        },
        "packageDownloadUrl": {
          "type": "string"
        },
        "localPackagePath": {
          "type": "string"
        },
        "readyAt": {
          "type": "string",
          "format": "date-time"
        },
        "message": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "packageReadiness": {
            "properties": {
              "status": {
                "const": "Ready"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "packageReadiness": {
            "required": [
              "packageDownloadUrl"
            ]
          }
        }
      }
    }
  ]
}
